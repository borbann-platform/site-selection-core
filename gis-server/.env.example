DATABASE_URL=postgresql://user:password@localhost:5432/gisdb
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_REGISTRY_URI=http://localhost:5001
DATASET_VERSION=local-dev

# =============================================================================
# Agent Configuration (LangGraph + Gemini)
# =============================================================================

# Google Gemini API Key (required for agent functionality)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Gemini model for chat/reasoning (default: gemini-2.0-flash)
AGENT_MODEL=gemini-2.0-flash

# Gemini model for embeddings (default: models/text-embedding-004)
EMBEDDING_MODEL=models/text-embedding-004

# Agent safety limits
AGENT_MAX_ITERATIONS=5
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_MAX_TOKENS_PER_TURN=4096

# RAG retrieval settings
RAG_RETRIEVAL_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50


#JWT Secret Key
JWT_SECRET_KEY=something-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
