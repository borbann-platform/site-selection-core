DATABASE_URL=postgresql://user:password@localhost:5432/gisdb
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_REGISTRY_URI=http://localhost:5001
DATASET_VERSION=local-dev

# Object storage (MinIO / S3-compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=listing-images
MINIO_OBJECT_PREFIX=scraped-listings

# =============================================================================
# Agent Configuration (Provider-Agnostic)
# =============================================================================

# Active provider: gemini | openai_compatible
AGENT_PROVIDER=openai_compatible

# Reasoning mode: react | cot | hybrid
AGENT_REASONING_MODE=hybrid

# Clarification loop for ambiguous prompts
AGENT_ENABLE_CLARIFICATION_LOOP=true

# Maximum DAG task nodes in decomposition phase
AGENT_DECOMPOSITION_MAX_NODES=6

# -----------------------------------------------------------------------------
# Gemini Configuration (AI Studio / Vertex AI)
# -----------------------------------------------------------------------------

# Gemini API key for AI Studio mode
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Gemini model for chat/reasoning
AGENT_MODEL=gemini-2.5-flash-lite

# Vertex AI mode (set true to use Vertex instead of AI Studio key auth)
GEMINI_USE_VERTEX_AI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# -----------------------------------------------------------------------------
# OpenAI-Compatible Configuration (OpenAI, Ollama, vLLM, Groq, DeepSeek gateways)
# -----------------------------------------------------------------------------

OPENAI_MODEL=deepseek-chat
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_ORG_ID=

# Encryption secret for BYOK credentials persisted in database.
# If empty, JWT_SECRET_KEY is used as fallback.
AGENT_CREDENTIALS_ENCRYPTION_KEY=

# Gemini model for embeddings (default: models/text-embedding-004)
EMBEDDING_MODEL=models/text-embedding-004

# Agent safety limits
AGENT_MAX_ITERATIONS=12
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_MAX_TOKENS_PER_TURN=4096

# RAG retrieval settings
RAG_RETRIEVAL_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50


#JWT Secret Key
JWT_SECRET_KEY=something-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
