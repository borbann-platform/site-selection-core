APP_DOMAIN=example.com
APP_DOMAIN_WWW=www.example.com

IMAGE_TAG=latest
DB_IMAGE=ghcr.io/borbann-platform/site-selection-core-db
BACKEND_IMAGE=ghcr.io/borbann-platform/site-selection-core-backend
FRONTEND_IMAGE=ghcr.io/borbann-platform/site-selection-core-frontend
APP_IMAGE_PULL_POLICY=missing
RUN_APP_BOOTSTRAP=1

POSTGRES_DB=gisdb
POSTGRES_USER=gis
POSTGRES_PASSWORD=change-me

JWT_SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=1800
DB_STATEMENT_TIMEOUT_MS=15000

CACHE_BACKEND=redis
REDIS_KEY_PREFIX=site_select_core

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=listing-images
MINIO_OBJECT_PREFIX=scraped-listings

GOOGLE_API_KEY=
AGENT_PROVIDER=openai_compatible
AGENT_REASONING_MODE=hybrid
AGENT_MODEL=gemini-2.5-flash-lite
GEMINI_USE_VERTEX_AI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
OPENAI_MODEL=deepseek-chat
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_ORG_ID=
AGENT_CREDENTIALS_ENCRYPTION_KEY=
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_PROVIDER=gemini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AGENT_MAX_ITERATIONS=12
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_MAX_TOKENS_PER_TURN=4096
RAG_RETRIEVAL_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

LOG_LEVEL=INFO

PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=80
PGBOUNCER_RESERVE_POOL_SIZE=20
PGBOUNCER_RESERVE_POOL_TIMEOUT=5

BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=3000
BACKEND_WORKERS=2
TS_TAILSCALE_IP=100.64.0.10

BACKEND_RUNTIME_DATA_DIR=./runtime/gis-server/data
BACKEND_RUNTIME_MODELS_DIR=./runtime/gis-server/models
